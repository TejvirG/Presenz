# Root ignore file for the Presenz repository

# Node backend dependencies
backend/node_modules/
backend/package-lock.json
backend/.env
backend/.env.*
backend/.git-backup/

# Flutter build artifacts
frontend/.dart_tool/
frontend/build/
frontend/.packages
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.metadata
frontend/.gradle/
frontend/ios/Pods/
frontend/ios/Flutter/
frontend/.idea/
frontend/.vscode/

# System files
.DS_Store
Thumbs.db
*.log
*.tmp
*.lock

# Git backup metadata
backend/.git-backup/
frontend/.git-backup/
